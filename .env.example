# Neon serverless Postgres connection string.
# Create a project at https://neon.tech, copy the connection string from the
# dashboard, and paste it here. Leave DATABASE_URL unset to run fully
# in-memory (data reseeds on every restart).
#
# Neon requires SSL; keep the sslmode=require parameter it gives you.
DATABASE_URL=postgresql://<user>:<password>@<endpoint>.neon.tech/<database>?sslmode=require

# Optional: base URL used by the in-process service clients (see services.py).
# HC_BASE_URL=http://127.0.0.1:5000
