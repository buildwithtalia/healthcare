# Copy this file to .env and fill in your values.
# The app reads these at startup via python-dotenv.

# MongoDB connection string.
# Local default:
MONGO_URI=mongodb://localhost:27017

# For MongoDB Atlas, use a connection string like:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/?retryWrites=true&w=majority

# Name of the database to use (default: healthcare)
MONGO_DB=healthcare
